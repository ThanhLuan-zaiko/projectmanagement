# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==========================================
# Dependencies
# ==========================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.bun/*
!.bun/install
# bun.lockb (Bun lockfile - commit if using Bun)

# ==========================================
# Testing
# ==========================================
/coverage

# ==========================================
# Next.js
# ==========================================
/.next/
/out/
next-env.d.ts

# ==========================================
# Production
# ==========================================
/build
/dist

# ==========================================
# Misc
# ==========================================
*.pem

# ==========================================
# Environment Files
# ==========================================
# Ignore all .env files by default
.env*
# .env.example should be committed
!.env.example

# ==========================================
# IDE & Editor
# ==========================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
*.swp
*.swo
*~
.project
.settings/

# ==========================================
# OS Files
# ==========================================
.DS_Store
.DS_Store?
Thumbs.db
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ==========================================
# Debug & Logs
# ==========================================
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ==========================================
# Vercel
# ==========================================
.vercel

# ==========================================
# TypeScript
# ==========================================
*.tsbuildinfo
next-env.d.ts

# ==========================================
# Bun Cache
# ==========================================
/node_modules/.cache

# ==========================================
# Archives (Optional)
# ==========================================
*.zip
*.tar.gz
*.rar

*.md
!/README.md