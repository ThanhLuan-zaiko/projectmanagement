# ==========================================
# Project Management - Environment Variables
# ==========================================
# Copy this file to .env.local and fill in the values
# Never commit .env.local to version control!

# ==========================================
# ScyllaDB Configuration
# ==========================================
SCYLLA_DB_HOST=localhost
SCYLLA_DB_PORT=9042
SCYLLA_DB_KEYSPACE=project_management
SCYLLA_DB_LOCAL_DATACENTER=datacenter1

# ==========================================
# Application Configuration
# ==========================================
NEXT_PUBLIC_APP_NAME=Project Management
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# Authentication (Optional - Add when needed)
# ==========================================
# AUTH_SECRET=your-secret-key-here
# AUTH_URL=http://localhost:3000/api/auth

# ==========================================
# Email Configuration (Optional - Add when needed)
# ==========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@example.com

# ==========================================
# File Upload Configuration (Optional)
# ==========================================
# UPLOAD_MAX_SIZE=10485760
# UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf
